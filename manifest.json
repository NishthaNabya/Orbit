{
  "manifest_version": 3,
  "name": "Orbit",
  "version": "2.0.1",
  "description": "Frictionless knowledge capture via fetch interception. Bookmark on X, right-click anywhere, and it lands in your local vault.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.x.com/*",
    "*://x.com/*",
    "*://*.twitter.com/*",
    "*://twitter.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.x.com/*",
        "*://x.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "interceptor.js"
      ],
      "matches": [
        "*://*.x.com/*",
        "*://x.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Orbit"
  }
}
